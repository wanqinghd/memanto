{
  "name": "@moorcheh-ai/memanto",
  "version": "0.2.3",
  "description": "TypeScript SDK for Memanto — memory that AI agents love.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "openapi:fetch": "node scripts/fetch-openapi.mjs",
    "openapi:generate": "openapi-ts",
    "openapi:regenerate": "npm run openapi:fetch && npm run openapi:generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "memanto",
    "memory",
    "ai",
    "agents",
    "moorcheh",
    "rag"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/moorcheh-ai/memanto.git",
    "directory": "sdks/typescript"
  }
}
